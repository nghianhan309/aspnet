@model CMS.Data.Entities.CategoryProduct

@{
    ViewData["Title"] = "Thêm danh mục sản phẩm";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4" style="background: rgba(30, 41, 59, 0.5); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.08) !important;">
                <div class="card-header border-0 py-4" style="background: linear-gradient(135deg, #1e293b, #0f172a); border-radius: 1rem 1rem 0 0;">
                    <h3 class="mb-0 fw-bold" style="background: linear-gradient(135deg, #38bdf8, #818cf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                        <i class="fas fa-plus-circle me-2" style="color: #38bdf8;"></i>THÊM DANH MỤC MỚI
                    </h3>
                </div>

                <div class="card-body p-4 text-light">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold" style="color: #e2e8f0;">Tên danh mục <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control bg-transparent text-light" style="border: 1px solid rgba(255,255,255,0.2); border-radius: 0.5rem; padding: 0.75rem;" placeholder="Nhập tên danh mục..." />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-5">
                            <label asp-for="Description" class="form-label fw-bold" style="color: #e2e8f0;">Mô tả chi tiết</label>
                            <textarea asp-for="Description" class="form-control bg-transparent text-light" rows="4" style="border: 1px solid rgba(255,255,255,0.2); border-radius: 0.5rem; padding: 0.75rem;" placeholder="Nhập mô tả..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-primary px-4 py-2 rounded-pill fw-semibold" style="background: linear-gradient(135deg, #38bdf8, #818cf8); border: none; box-shadow: 0 4px 15px rgba(56, 189, 248, 0.3);">
                                <i class="fas fa-save me-1"></i> Lưu dữ liệu
                            </button>
                            <a asp-action="Index" class="btn btn-secondary px-4 py-2 rounded-pill fw-semibold" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: #f8fafc;">
                                <i class="fas fa-arrow-left me-1"></i> Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
