@model IEnumerable<CMS.Data.Entities.CategoryProduct>

@{
    ViewData["Title"] = "Danh mục sản phẩm";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0 rounded-4" style="background: rgba(30, 41, 59, 0.5); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.08) !important;">
        <div class="card-header border-0 py-4" style="background: linear-gradient(135deg, #1e293b, #0f172a); border-radius: 1rem 1rem 0 0;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="mb-0 fw-bold" style="background: linear-gradient(135deg, #38bdf8, #818cf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                        <i class="fas fa-layer-group me-2" style="color: #38bdf8;"></i>DANH MỤC SẢN PHẨM
                    </h3>
                    <p class="text-secondary small mb-0 mt-1">Quản lý các nhóm phân loại sản phẩm</p>
                </div>
                <a asp-action="Create" class="btn btn-primary px-4 py-2 rounded-pill fw-semibold" style="background: linear-gradient(135deg, #38bdf8, #818cf8); border: none; box-shadow: 0 4px 15px rgba(56, 189, 248, 0.3);">
                    <i class="fas fa-plus-circle me-1"></i> Thêm danh mục
                </a>
            </div>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover table-borderless mb-0 align-middle text-light" style="--bs-table-bg: transparent; --bs-table-hover-bg: rgba(255, 255, 255, 0.05);">
                <thead style="background: rgba(15, 23, 42, 0.6); border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <tr>
                        <th style="width: 10%" class="ps-4 text-secondary text-uppercase font-weight-bold">ID</th>
                        <th style="width: 30%" class="text-secondary text-uppercase font-weight-bold">Tên danh mục</th>
                        <th style="width: 45%" class="text-secondary text-uppercase font-weight-bold">Mô tả</th>
                        <th style="width: 15%" class="text-end pe-4 text-secondary text-uppercase font-weight-bold">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.05); transition: background-color 0.3s ease;">
                                <td class="ps-4">
                                    <span class="badge rounded-pill" style="background: rgba(56, 189, 248, 0.1); color: #38bdf8; border: 1px solid rgba(56, 189, 248, 0.2);">#@item.Id</span>
                                </td>
                                <td>
                                    <span class="fw-bold" style="color: #f8fafc;">@item.Name</span>
                                </td>
                                <td>
                                    <span class="text-secondary d-inline-block text-truncate" style="max-width: 400px;">
                                        @(string.IsNullOrEmpty(item.Description) ? "Chưa có mô tả" : item.Description)
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <button class="btn btn-sm mx-1 rounded-circle" style="background: rgba(245, 158, 11, 0.1); color: #fcd34d; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; transition: all 0.2s;" title="Sửa (Chưa hỗ trợ)">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-sm mx-1 rounded-circle" style="background: rgba(244, 63, 94, 0.1); color: #fda4af; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; transition: all 0.2s;" title="Xóa (Chưa hỗ trợ)">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <i class="fas fa-layer-group text-secondary mb-3" style="font-size: 3rem; opacity: 0.5;"></i>
                                <h5 class="text-secondary">Chưa có danh mục nào</h5>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="card-footer border-0 py-3 text-center" style="background: rgba(15, 23, 42, 0.6); border-radius: 0 0 1rem 1rem;">
            <small class="text-secondary">Hiển thị tổng số @(Model?.Count() ?? 0) danh mục sản phẩm</small>
        </div>
    </div>
</div>

<style>
    .btn-group .btn:hover {
        transform: translateY(-2px);
        filter: brightness(1.2);
    }
</style>