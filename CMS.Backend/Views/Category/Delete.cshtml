@model CMS.Data.Entities.Category

@{
    ViewData["Title"] = "Xóa Danh mục";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0 rounded-3 border-danger border-top border-4">
        <div class="card-header bg-white py-3">
            <h4 class="mb-0 text-danger"><i class="fas fa-exclamation-triangle me-2"></i>Xác Nhận Xóa Danh Mục</h4>
        </div>
        <div class="card-body p-4 bg-light">
            <p class="fs-5 text-dark">Bạn có chắc chắn muốn xóa danh mục này không? Hành động này không thể hoàn tác.</p>
            
            <div class="bg-white p-4 rounded-3 border mt-4">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted">Mã danh mục</dt>
                    <dd class="col-sm-9 fw-bold">#@Model.Id</dd>

                    <dt class="col-sm-3 text-muted">Tên danh mục</dt>
                    <dd class="col-sm-9 fw-bold text-danger">@Model.Name</dd>

                    <dt class="col-sm-3 text-muted">Mô tả chi tiết</dt>
                    <dd class="col-sm-9">
                        @(string.IsNullOrEmpty(Model.Description) ? "Chưa có mô tả" : Model.Description)
                    </dd>
                </dl>
            </div>
        </div>
        <div class="card-footer bg-white p-3 border-top-0">
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger px-4 fw-bold">
                        <i class="fas fa-trash-alt me-1"></i> Xác nhận xóa
                    </button>
                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="fas fa-times me-1"></i> Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
