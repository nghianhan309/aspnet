@model CMS.Data.Entities.Category

@{
    ViewData["Title"] = "Chi tiết Danh mục";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-info text-white py-3">
            <h4 class="mb-0"><i class="fas fa-info-circle me-2"></i>Thông Tin Danh Mục</h4>
        </div>
        <div class="card-body p-4">
            <dl class="row">
                <dt class="col-sm-3 text-muted">Mã danh mục</dt>
                <dd class="col-sm-9 fw-bold">#@Model.Id</dd>

                <dt class="col-sm-3 text-muted">Tên danh mục</dt>
                <dd class="col-sm-9 text-primary fw-bold fs-5">@Model.Name</dd>

                <dt class="col-sm-3 text-muted">Mô tả chi tiết</dt>
                <dd class="col-sm-9">
                    @(string.IsNullOrEmpty(Model.Description) ? "Chưa có mô tả" : Model.Description)
                </dd>
            </dl>
        </div>
        <div class="card-footer bg-light p-3">
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning text-dark fw-bold px-4">
                    <i class="fas fa-edit me-1"></i> Chỉnh sửa
                </a>
                <a asp-action="Index" class="btn btn-secondary px-4">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</div>
